---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { withBasePath } from "@lib/posts";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "san2blog",
  description = "개발 기록, 영어 메모, 프로젝트를 정리하는 개인 블로그입니다."
} = Astro.props;

const pageTitle = title === "san2blog" ? title : `${title} | san2blog`;
const rssUrl = new URL(withBasePath("rss.xml"), Astro.site).toString();
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={withBasePath("favicon.svg")} />
    <link rel="alternate" type="application/rss+xml" title="san2blog RSS" href={rssUrl} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
