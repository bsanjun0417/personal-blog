---
import Layout from "@layouts/Layout.astro";
import PostCard from "@components/PostCard.astro";
import { categoryLabels, getPublishedPosts, type Post } from "@lib/posts";

export function getStaticPaths() {
  return Object.keys(categoryLabels).map((category) => ({
    params: { category }
  }));
}

const category = Astro.params.category as Post["data"]["category"];
const posts = (await getPublishedPosts()).filter((post) => post.data.category === category);
const label = categoryLabels[category] ?? category;
---

<Layout title={`${label} 글`} description={`${label} 카테고리 글 목록`}>
  <section class="page-hero section">
    <p class="section-label">Category</p>
    <h1>{label}</h1>
    <p>{posts.length}개의 글이 있습니다.</p>
  </section>

  <section class="section post-list">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</Layout>
