---
import Layout from "@layouts/Layout.astro";
import PostCard from "@components/PostCard.astro";
import { categoryLabels, formatDate, getPostPath, getPublishedPosts } from "@lib/posts";

const posts = await getPublishedPosts();
const latestPosts = posts.slice(0, 3);
const featuredPost = latestPosts[0];
---

<Layout>
  <section class="home-intro section">
    <div>
      <p class="section-label">san2blog</p>
      <h1>작게 쓰고, 다시 찾기 쉽게.</h1>
      <p>
        개발 기록, 영어 메모, 프로젝트 노트를 Markdown으로 정리하는 개인 블로그입니다.
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/posts">글 목록</a>
      </div>
    </div>

    {featuredPost && (
      <a class="featured-visual" href={getPostPath(featuredPost)} aria-label={featuredPost.data.title}>
        {featuredPost.data.cover ? (
          <img src={featuredPost.data.cover.src} alt="" loading="eager" />
        ) : (
          <div class="featured-cover" aria-hidden="true">
            <span>{categoryLabels[featuredPost.data.category]}</span>
            <strong>{featuredPost.data.title}</strong>
          </div>
        )}
        <div class="featured-caption">
          <span>{formatDate(featuredPost.data.date)}</span>
          <strong>{featuredPost.data.title}</strong>
        </div>
      </a>
    )}
  </section>

  <section class="section latest-section">
    <div class="section-heading">
      <div>
        <p class="section-label">Latest</p>
        <h2>최근 글</h2>
      </div>
      <a class="text-link" href="/posts">전체 보기</a>
    </div>
    <div class="post-grid compact-posts">
      {latestPosts.map((post) => <PostCard post={post} compact />)}
    </div>
  </section>
</Layout>
