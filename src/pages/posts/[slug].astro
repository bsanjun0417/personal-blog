---
import Layout from "@layouts/Layout.astro";
import { categoryLabels, formatDate, getPostPath, getPublishedPosts } from "@lib/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;
const posts = await getPublishedPosts();
const currentIndex = posts.findIndex((item) => item.id === post.id);
const newerPost = posts[currentIndex - 1];
const olderPost = posts[currentIndex + 1];
const { Content, headings } = await post.render();
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="post-detail section">
    <header class="post-header">
      <div class="post-meta">
        <a href={`/categories/${post.data.category}`}>{categoryLabels[post.data.category]}</a>
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
      </div>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="tag-row">
        {post.data.tags.map((tag) => <a href={`/tags/${tag}`}>#{tag}</a>)}
      </div>
    </header>

    <div class="post-shell">
      <div class="prose" data-pagefind-body>
        <Content />
      </div>
      {tocHeadings.length > 0 && (
        <aside class="toc" aria-label="글 목차">
          <strong>목차</strong>
          <nav>
            {tocHeadings.map((heading) => (
              <a class={`depth-${heading.depth}`} href={`#${heading.slug}`}>
                {heading.text}
              </a>
            ))}
          </nav>
        </aside>
      )}
    </div>

    <nav class="post-nav" aria-label="이전 글과 다음 글">
      {olderPost ? (
        <a href={getPostPath(olderPost)}>
          <span>이전 글</span>
          {olderPost.data.title}
        </a>
      ) : <span></span>}
      {newerPost ? (
        <a href={getPostPath(newerPost)}>
          <span>다음 글</span>
          {newerPost.data.title}
        </a>
      ) : <span></span>}
    </nav>
  </article>
</Layout>
