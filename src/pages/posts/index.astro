---
import Layout from "@layouts/Layout.astro";
import PostCard from "@components/PostCard.astro";
import { getAllTags, getCategoryCounts, getPublishedPosts } from "@lib/posts";

const posts = await getPublishedPosts();
const categories = getCategoryCounts(posts);
const tags = getAllTags(posts);
---

<Layout title="Posts" description="전체 글 목록">
  <section class="page-hero section">
    <p class="section-label">Posts</p>
    <h1>전체 글</h1>
  </section>

  <section class="section filter-section">
    <div class="filter-group">
      <h2>카테고리</h2>
      <div class="chip-row">
        {categories.map((category) => (
          <a href={`/categories/${category.key}`}>{category.label} {category.count}</a>
        ))}
      </div>
    </div>
    <div class="filter-group">
      <h2>태그</h2>
      <div class="chip-row">
        {tags.map((tag) => <a href={`/tags/${tag}`}>#{tag}</a>)}
      </div>
    </div>
  </section>

  <section class="section post-list">
    {posts.map((post) => <PostCard post={post} />)}
  </section>
</Layout>
