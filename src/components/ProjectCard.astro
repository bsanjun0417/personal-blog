---
interface Props {
  title: string;
  description: string;
  stack: string[];
  githubUrl: string;
}

const { title, description, stack, githubUrl } = Astro.props;
---

<article class="project-card">
  <h2>{title}</h2>
  <p>{description}</p>
  <div class="tag-row">
    {stack.map((item) => <span>{item}</span>)}
  </div>
  <a class="text-link" href={githubUrl} rel="noreferrer">GitHub 보기</a>
</article>
