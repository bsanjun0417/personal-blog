---
import PostCard from "@components/PostCard.astro";
import type { Post } from "@lib/posts";

interface CategoryNode {
  key: Post["data"]["category"];
  label: string;
  count: number;
  subcategories: {
    key: string;
    label: string;
    count: number;
  }[];
}

interface Props {
  posts: Post[];
  categories: CategoryNode[];
  recentTags: string[];
  currentPage: number;
  pageCount: number;
}

const { posts, categories, recentTags, currentPage, pageCount } = Astro.props;
const pages = Array.from({ length: pageCount }, (_, index) => index + 1);
const getPageHref = (page: number) => page === 1 ? "/posts" : `/posts/page/${page}`;
const firstActiveCategoryIndex = categories.findIndex((category) => category.count > 0);
const openCategoryIndex = firstActiveCategoryIndex === -1 ? 0 : firstActiveCategoryIndex;
---

<div class="posts-layout">
  <div class="posts-main">
    <section class="category-panel" aria-labelledby="category-heading">
      <div class="category-panel-heading">
        <p class="section-label">Categories</p>
        <h2 id="category-heading">카테고리</h2>
      </div>
      <div class="category-tree">
        {categories.map((category, index) => (
          <details class="category-branch" open={index === openCategoryIndex}>
            <summary>
              <span>{category.label}</span>
              <small>{category.count}</small>
            </summary>
            <div class="subcategory-list">
              <div>
                <a class="subcategory-all" href={`/categories/${category.key}`}>
                  <span>전체 보기</span>
                  <small>{category.count}</small>
                </a>
                {category.subcategories.length > 0 ? (
                  category.subcategories.map((subcategory) => (
                    <a href={`/tags/${subcategory.key}`}>
                      <span>#{subcategory.label}</span>
                      <small>{subcategory.count}</small>
                    </a>
                  ))
                ) : (
                  <span class="subcategory-empty">아직 하위 주제가 없습니다.</span>
                )}
              </div>
            </div>
          </details>
        ))}
      </div>
    </section>

    <section class="post-list posts-paged-list" aria-label="글 목록">
      {posts.map((post) => <PostCard post={post} />)}
    </section>

    {pageCount > 1 && (
      <nav class="pagination" aria-label="페이지네이션">
        {currentPage > 1 ? (
          <a class="pagination-edge" href={getPageHref(currentPage - 1)}>이전</a>
        ) : (
          <span class="pagination-edge is-disabled">이전</span>
        )}
        <div class="pagination-pages">
          {pages.map((page) => (
            <a
              href={getPageHref(page)}
              aria-current={page === currentPage ? "page" : undefined}
            >
              {page}
            </a>
          ))}
        </div>
        {currentPage < pageCount ? (
          <a class="pagination-edge" href={getPageHref(currentPage + 1)}>다음</a>
        ) : (
          <span class="pagination-edge is-disabled">다음</span>
        )}
      </nav>
    )}
  </div>

  <aside class="recent-tags-sidebar" aria-labelledby="recent-tags-heading">
    <h2 id="recent-tags-heading">Recent Tags</h2>
    <div class="recent-tag-cloud">
      {recentTags.map((tag) => <a href={`/tags/${tag}`}>#{tag}</a>)}
    </div>
  </aside>
</div>
