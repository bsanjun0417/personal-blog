---
import { categoryLabels, formatDate, getPostPath, type Post } from "@lib/posts";

interface Props {
  post: Post;
  compact?: boolean;
}

const { post, compact = false } = Astro.props;
const postPath = getPostPath(post);
// 목록 카드는 태그 대신 썸네일을 보여주고, 홈의 compact 카드는 기존처럼 가볍게 유지한다.
const visibleTags = compact ? post.data.tags.slice(0, 3) : [];
---

<article class:list={["post-card", { "post-card-compact": compact }]}>
  <div class="post-card-main">
    {!compact && (
      <div class="post-meta">
        <a href={`/categories/${post.data.category}`}>{categoryLabels[post.data.category]}</a>
        <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
      </div>
    )}
    <h2><a href={postPath}>{post.data.title}</a></h2>
    {!compact && <p>{post.data.description}</p>}
  </div>
  {!compact && (
    <a class="post-thumbnail" href={postPath} aria-label={post.data.title}>
      {post.data.cover ? (
        <img src={post.data.cover.src} alt="" loading="lazy" />
      ) : (
        <span>{categoryLabels[post.data.category]}</span>
      )}
    </a>
  )}
  {visibleTags.length > 0 && (
    <div class:list={["tag-row", { "compact-tag-row": compact }]} aria-label="태그">
      {visibleTags.map((tag) => <a href={`/tags/${tag}`}>#{tag}</a>)}
    </div>
  )}
</article>
